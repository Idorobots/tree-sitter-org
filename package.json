{
  "name": "tree-sitter-org",
  "version": "0.1.0",
  "description": "Tree-sitter grammar for Org Mode syntax",
  "license": "MIT",
  "keywords": [
    "parser",
    "tree-sitter",
    "org-mode",
    "org"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Idorobots/tree-sitter-org.git"
  },
  "files": [
    "grammar.js",
    "queries/*",
    "src/**",
    "*.wasm"
  ],
  "devDependencies": {
    "tree-sitter-cli": "^0.26.0"
  },
  "scripts": {
    "build": "tree-sitter generate && tree-sitter build",
    "generate": "tree-sitter generate",
    "test": "tree-sitter test",
    "parse": "tree-sitter parse"
  },
  "tree-sitter": [
    {
      "scope": "source.org",
      "file-types": [
        "org"
      ],
      "highlights": "queries/highlights.scm",
      "injection-regex": "^org$"
    }
  ]
}
