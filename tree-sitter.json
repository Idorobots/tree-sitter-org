{
  "grammars": [
    {
      "name": "org",
      "camelcase": "Org",
      "scope": "source.org",
      "path": ".",
      "file-types": [
        "org"
      ],
      "highlights": "queries/highlights.scm",
      "injection-regex": "^org$"
    }
  ],
  "metadata": {
    "version": "0.23.7",
    "license": "MIT",
    "description": "Tree-sitter grammar for Org Mode syntax",
    "authors": [],
    "links": {
      "repository": "https://github.com/Idorobots/tree-sitter-org"
    }
  },
  "bindings": {
    "c": true,
    "go": false,
    "node": true,
    "python": true,
    "rust": false,
    "swift": false
  }
}
